    "+misc.Motd",
    "misc.HumanHealth=100[50-200]",
    "-misc.RealismMode",
    "-misc.RealismImpactThreshold",
    "-misc.RealismMaxReel",
    "-misc.RealismMaxSpeed",

    "!titan.TitanSpawnEnabled=false",
